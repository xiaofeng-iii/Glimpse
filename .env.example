# Glimpse - AI 桌面记忆助手
# 环境变量配置文件
# 复制此文件为 .env 并填写你的配置

# OpenAI 兼容接口配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：模型 / 端点配置
# 对 OpenAI 官方接口可不填，交给代码默认值处理。
# MODEL=gpt-4o-mini
#
# 如果使用豆包（火山引擎 Ark）一类 OpenAI 兼容平台，
# MODEL 必须填写“可调用的 endpoint / model id”，不要填写展示名称。
# 例如：
# OPENAI_API_KEY=ark-xxxxxxxx
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MODEL=doubao-seed-1-8-251228

# 开发模式
# DEBUG=true
